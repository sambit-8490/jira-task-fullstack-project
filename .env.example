# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fsa_user:fsa_password@postgres:5432/fsa_db

# Test database (used by Jest integration tests)
TEST_DATABASE_URL=postgresql://fsa_user:fsa_password@localhost:5432/fsa_test_db

# ─── PostgreSQL Container Credentials ─────────────────────────────────────────
POSTGRES_USER=fsa_user
POSTGRES_PASSWORD=fsa_password
POSTGRES_DB=fsa_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change these to strong random strings in production (min 32 chars)
JWT_ACCESS_SECRET=change-this-access-secret-must-be-at-least-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Exports ──────────────────────────────────────────────────────────────────
EXPORTS_DIR=./exports

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
