# Copy this to .env for local development (outside Docker)
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://fsa_user:fsa_password@localhost:5432/fsa_db
TEST_DATABASE_URL=postgresql://fsa_user:fsa_password@localhost:5432/fsa_test_db
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-this-access-secret-must-be-at-least-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EXPORTS_DIR=./exports
FRONTEND_URL=http://localhost:5173
